# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# Model Configuration
MODEL_NAME=gpt2
MODEL_PATH=./models

# Training Configuration
BATCH_SIZE=32
LEARNING_RATE=0.001
EPOCHS=10

# Data Configuration
DATA_PATH=./data
OUTPUT_PATH=./output

# API Keys (if applicable)
# API_KEY=your_api_key_here
